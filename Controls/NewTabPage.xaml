<UserControl x:Class="MDViewer.Controls.NewTabPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BgMain}">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                    MaxWidth="520" Margin="32">

            <!-- Title -->
            <TextBlock Text="MD Viewer" FontSize="30" FontWeight="Light"
                       Foreground="{DynamicResource FgMain}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Просмотр Markdown файлов" FontSize="13"
                       Foreground="{DynamicResource FgMuted}"
                       HorizontalAlignment="Center" Margin="0,6,0,40"/>

            <!-- Recent projects -->
            <TextBlock Text="НЕДАВНИЕ ПРОЕКТЫ" FontSize="10" FontWeight="Bold"
                       Foreground="{DynamicResource FgMuted}" Margin="0,0,0,10"/>

            <Border x:Name="NoRecentHint" Visibility="Collapsed"
                    Background="{DynamicResource BgSidebar}"
                    BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                    CornerRadius="6" Padding="20">
                <TextBlock Text="Нет недавних проектов"
                           Foreground="{DynamicResource FgMuted}"
                           HorizontalAlignment="Center"/>
            </Border>

            <StackPanel x:Name="RecentList"/>

            <!-- Divider -->
            <Border Height="1" Background="{DynamicResource BorderColor}" Margin="0,14,0,14"/>

            <!-- Open new project button -->
            <Button x:Name="OpenNewBtn" Height="42"
                    Content="＋  Открыть новый проект"
                    FontSize="14" Cursor="Hand" Click="OpenNew_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{DynamicResource Accent}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextBlock.Foreground="White" TextBlock.FontSize="14"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource AccentHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource AccentPress}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

        </StackPanel>
    </Grid>
</UserControl>
