<UserControl x:Class="MDViewer.Controls.ProjectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:MDViewer.Models"
             Background="{DynamicResource BgMain}">

    <UserControl.Resources>
        <Style x:Key="PathBarBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource FgMain}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}"
                                              TextBlock.FontSize="{TemplateBinding FontSize}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.25"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsEnabled" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource Hover}"/>
                                <Setter Property="Foreground" Value="{DynamicResource FgMain}"/>
                            </MultiTrigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsPressed" Value="True"/>
                                    <Condition Property="IsEnabled" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bg" Property="Background" Value="{DynamicResource Selected}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="200"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="280" MinWidth="160" MaxWidth="600"/>
        </Grid.ColumnDefinitions>

        <!-- === MARKDOWN PREVIEW === -->
        <Border Grid.Column="0" Background="{DynamicResource BgMain}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- File path bar -->
                <Border Grid.Row="0" Background="{DynamicResource BgSidebar}" Height="30"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Button x:Name="BackBtn" Content="←" FontSize="14"
                                    Width="28" Height="30" IsEnabled="False"
                                    Style="{StaticResource PathBarBtn}"
                                    Click="BackBtn_Click" ToolTip="Назад"/>
                            <Button x:Name="FwdBtn" Content="→" FontSize="14"
                                    Width="28" Height="30" IsEnabled="False"
                                    Style="{StaticResource PathBarBtn}"
                                    Click="FwdBtn_Click" ToolTip="Вперёд"/>
                        </StackPanel>
                        <TextBlock x:Name="CurrentFilePath" Grid.Column="1"
                                   Foreground="{DynamicResource FgMain}" FontSize="12"
                                   VerticalAlignment="Center" Margin="4,0"
                                   TextTrimming="CharacterEllipsis"
                                   Text="Выберите файл в дереве →"/>
                        <Button x:Name="PrintBtn" Grid.Column="2"
                                Content="🖨" FontSize="14"
                                Width="30" Height="30" IsEnabled="False"
                                Style="{StaticResource PathBarBtn}"
                                Click="PrintBtn_Click" ToolTip="Печать"/>
                    </Grid>
                </Border>

                <!-- Welcome placeholder -->
                <Border x:Name="WelcomePlaceholder" Grid.Row="1"
                        Background="{DynamicResource BgMain}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Opacity="0.35">
                        <TextBlock Text="📄" FontSize="48" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="PlaceholderMsg" Text="Выберите .md файл"
                                   FontSize="16" Foreground="{DynamicResource FgMain}"
                                   HorizontalAlignment="Center" Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>

                <!-- WebBrowser for markdown rendering -->
                <WebBrowser x:Name="Browser" Grid.Row="1"
                            Visibility="Collapsed"
                            Navigating="Browser_Navigating"/>
            </Grid>
        </Border>

        <!-- === SPLITTER === -->
        <GridSplitter Grid.Column="1"
                      Background="{DynamicResource BorderColor}"
                      HorizontalAlignment="Stretch"
                      ResizeBehavior="PreviousAndNext"
                      ShowsPreview="False"
                      Cursor="SizeWE"/>

        <!-- === FILE TREE === -->
        <Border Grid.Column="2" Background="{DynamicResource BgSidebar}"
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Project header -->
                <Border Grid.Row="0" Background="{DynamicResource BgTabBar}" Height="36"
                        BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1">
                    <Grid Margin="8,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="📁" FontSize="14" VerticalAlignment="Center"
                                   Margin="0,0,6,0"/>
                        <TextBlock x:Name="ProjectNameText" Grid.Column="1"
                                   Foreground="{DynamicResource FgMain}"
                                   FontSize="12" FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                    </Grid>
                </Border>

                <!-- Tree view -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Background="{DynamicResource BgSidebar}">
                    <TreeView x:Name="FileTree"
                              Background="Transparent"
                              BorderThickness="0"
                              Padding="4"
                              TreeViewItem.Expanded="FileTree_ItemExpanded"
                              SelectedItemChanged="FileTree_SelectedItemChanged">
                        <TreeView.Resources>
                            <HierarchicalDataTemplate DataType="{x:Type models:FileTreeItem}"
                                                      ItemsSource="{Binding Children}">
                                <StackPanel Orientation="Horizontal" Height="20"
                                            Tag="{Binding}"
                                            ContextMenuOpening="TreeItem_ContextMenuOpening">
                                    <StackPanel.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Посмотреть содержимое" Click="TreeMenu_ViewContents"/>
                                            <MenuItem Header="Открыть расположение"  Click="TreeMenu_OpenLocation"/>
                                            <Separator/>
                                            <MenuItem Header="Удалить" Click="TreeMenu_Delete"/>
                                        </ContextMenu>
                                    </StackPanel.ContextMenu>
                                    <TextBlock Text="{Binding Icon}"
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource FgMain}"/>
                                </StackPanel>
                            </HierarchicalDataTemplate>
                        </TreeView.Resources>
                    </TreeView>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
