<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- WPF brushes -->
    <SolidColorBrush x:Key="BgMain"                Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BgSidebar"             Color="#F6F8FA"/>
    <SolidColorBrush x:Key="BgTabBar"              Color="#ECECEC"/>
    <SolidColorBrush x:Key="BgPopup"               Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BgInput"               Color="#F6F8FA"/>
    <SolidColorBrush x:Key="FgMain"                Color="#24292F"/>
    <SolidColorBrush x:Key="FgMuted"               Color="#57606A"/>
    <SolidColorBrush x:Key="Accent"                Color="#0969DA"/>
    <SolidColorBrush x:Key="AccentHover"           Color="#0860CA"/>
    <SolidColorBrush x:Key="AccentPress"           Color="#064FAC"/>
    <SolidColorBrush x:Key="BorderColor"           Color="#D0D7DE"/>
    <SolidColorBrush x:Key="Hover"                 Color="#E9ECEF"/>
    <SolidColorBrush x:Key="Selected"              Color="#DDF4FF"/>
    <SolidColorBrush x:Key="TabActive"             Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TabInactive"           Color="#ECECEC"/>
    <SolidColorBrush x:Key="TabActiveIndicator"    Color="#0969DA"/>
    <SolidColorBrush x:Key="TreeHoverBg"           Color="#F1F2F4"/>
    <SolidColorBrush x:Key="TreeSelectedBg"        Color="#DDF4FF"/>
    <SolidColorBrush x:Key="TreeSelectedInactiveBg" Color="#EBF5FF"/>
    <SolidColorBrush x:Key="FgTreeSelected"        Color="#0969DA"/>

    <!-- Markdown CSS colors -->
    <sys:String x:Key="MdBg">#ffffff</sys:String>
    <sys:String x:Key="MdFg">#24292f</sys:String>
    <sys:String x:Key="MdHeading">#1f2328</sys:String>
    <sys:String x:Key="MdCode">#f6f8fa</sys:String>
    <sys:String x:Key="MdCodeFg">#953800</sys:String>
    <sys:String x:Key="MdCodeBlockFg">#24292f</sys:String>
    <sys:String x:Key="MdBorder">#d0d7de</sys:String>
    <sys:String x:Key="MdLink">#0969da</sys:String>
    <sys:String x:Key="MdQuote">#57606a</sys:String>
    <sys:String x:Key="MdTableEven">#f6f8fa</sys:String>
    <sys:String x:Key="MdThHead">#f6f8fa</sys:String>
    <sys:String x:Key="MdEm">#6e40c9</sys:String>
    <sys:String x:Key="MdStrong">#1f2328</sys:String>
    <sys:String x:Key="MdScrollThumb">#adb5bd</sys:String>
    <sys:String x:Key="MdScrollThumbHover">#636c76</sys:String>

</ResourceDictionary>
