<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- WPF brushes -->
    <SolidColorBrush x:Key="BgMain"                Color="#272822"/>
    <SolidColorBrush x:Key="BgSidebar"             Color="#1E1F1C"/>
    <SolidColorBrush x:Key="BgTabBar"              Color="#353630"/>
    <SolidColorBrush x:Key="BgPopup"               Color="#353630"/>
    <SolidColorBrush x:Key="BgInput"               Color="#3E3D32"/>
    <SolidColorBrush x:Key="FgMain"                Color="#F8F8F2"/>
    <SolidColorBrush x:Key="FgMuted"               Color="#75715E"/>
    <SolidColorBrush x:Key="Accent"                Color="#A6E22E"/>
    <SolidColorBrush x:Key="AccentHover"           Color="#B8F43E"/>
    <SolidColorBrush x:Key="AccentPress"           Color="#7AC220"/>
    <SolidColorBrush x:Key="BorderColor"           Color="#49483E"/>
    <SolidColorBrush x:Key="Hover"                 Color="#3E3D32"/>
    <SolidColorBrush x:Key="Selected"              Color="#49483E"/>
    <SolidColorBrush x:Key="TabActive"             Color="#272822"/>
    <SolidColorBrush x:Key="TabInactive"           Color="#353630"/>
    <SolidColorBrush x:Key="TabActiveIndicator"    Color="#A6E22E"/>
    <SolidColorBrush x:Key="TreeHoverBg"           Color="#3E3D32"/>
    <SolidColorBrush x:Key="TreeSelectedBg"        Color="#49483E"/>
    <SolidColorBrush x:Key="TreeSelectedInactiveBg" Color="#414238"/>
    <SolidColorBrush x:Key="FgTreeSelected"        Color="#F8F8F2"/>

    <!-- Markdown CSS colors -->
    <sys:String x:Key="MdBg">#272822</sys:String>
    <sys:String x:Key="MdFg">#f8f8f2</sys:String>
    <sys:String x:Key="MdHeading">#f92672</sys:String>
    <sys:String x:Key="MdCode">#1e1f1c</sys:String>
    <sys:String x:Key="MdCodeFg">#ae81ff</sys:String>
    <sys:String x:Key="MdCodeBlockFg">#f8f8f2</sys:String>
    <sys:String x:Key="MdBorder">#49483e</sys:String>
    <sys:String x:Key="MdLink">#66d9e8</sys:String>
    <sys:String x:Key="MdQuote">#75715e</sys:String>
    <sys:String x:Key="MdTableEven">#1e1f1c</sys:String>
    <sys:String x:Key="MdThHead">#3e3d32</sys:String>
    <sys:String x:Key="MdEm">#e6db74</sys:String>
    <sys:String x:Key="MdStrong">#fd971f</sys:String>
    <sys:String x:Key="MdScrollThumb">#6d6b5e</sys:String>
    <sys:String x:Key="MdScrollThumbHover">#908e7e</sys:String>

</ResourceDictionary>
