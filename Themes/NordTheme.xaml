<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- WPF brushes -->
    <SolidColorBrush x:Key="BgMain"                Color="#2E3440"/>
    <SolidColorBrush x:Key="BgSidebar"             Color="#272C37"/>
    <SolidColorBrush x:Key="BgTabBar"              Color="#3B4252"/>
    <SolidColorBrush x:Key="BgPopup"               Color="#3B4252"/>
    <SolidColorBrush x:Key="BgInput"               Color="#434C5E"/>
    <SolidColorBrush x:Key="FgMain"                Color="#ECEFF4"/>
    <SolidColorBrush x:Key="FgMuted"               Color="#7B8899"/>
    <SolidColorBrush x:Key="Accent"                Color="#88C0D0"/>
    <SolidColorBrush x:Key="AccentHover"           Color="#9BD0E0"/>
    <SolidColorBrush x:Key="AccentPress"           Color="#6AAFC0"/>
    <SolidColorBrush x:Key="BorderColor"           Color="#434C5E"/>
    <SolidColorBrush x:Key="Hover"                 Color="#434C5E"/>
    <SolidColorBrush x:Key="Selected"              Color="#3D5A7A"/>
    <SolidColorBrush x:Key="TabActive"             Color="#2E3440"/>
    <SolidColorBrush x:Key="TabInactive"           Color="#3B4252"/>
    <SolidColorBrush x:Key="TabActiveIndicator"    Color="#88C0D0"/>
    <SolidColorBrush x:Key="TreeHoverBg"           Color="#434C5E"/>
    <SolidColorBrush x:Key="TreeSelectedBg"        Color="#3D5A7A"/>
    <SolidColorBrush x:Key="TreeSelectedInactiveBg" Color="#364858"/>
    <SolidColorBrush x:Key="FgTreeSelected"        Color="#ECEFF4"/>

    <!-- Markdown CSS colors -->
    <sys:String x:Key="MdBg">#2e3440</sys:String>
    <sys:String x:Key="MdFg">#eceff4</sys:String>
    <sys:String x:Key="MdHeading">#88c0d0</sys:String>
    <sys:String x:Key="MdCode">#3b4252</sys:String>
    <sys:String x:Key="MdCodeFg">#a3be8c</sys:String>
    <sys:String x:Key="MdCodeBlockFg">#e5e9f0</sys:String>
    <sys:String x:Key="MdBorder">#434c5e</sys:String>
    <sys:String x:Key="MdLink">#88c0d0</sys:String>
    <sys:String x:Key="MdQuote">#7b8899</sys:String>
    <sys:String x:Key="MdTableEven">#3b4252</sys:String>
    <sys:String x:Key="MdThHead">#434c5e</sys:String>
    <sys:String x:Key="MdEm">#ebcb8b</sys:String>
    <sys:String x:Key="MdStrong">#d08770</sys:String>
    <sys:String x:Key="MdScrollThumb">#4c566a</sys:String>
    <sys:String x:Key="MdScrollThumbHover">#5e6e84</sys:String>

</ResourceDictionary>
