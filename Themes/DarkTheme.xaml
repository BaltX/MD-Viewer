<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- WPF brushes -->
    <SolidColorBrush x:Key="BgMain"                Color="#1E1E1E"/>
    <SolidColorBrush x:Key="BgSidebar"             Color="#252526"/>
    <SolidColorBrush x:Key="BgTabBar"              Color="#2D2D30"/>
    <SolidColorBrush x:Key="BgPopup"               Color="#252526"/>
    <SolidColorBrush x:Key="BgInput"               Color="#3C3C3C"/>
    <SolidColorBrush x:Key="FgMain"                Color="#CCCCCC"/>
    <SolidColorBrush x:Key="FgMuted"               Color="#858585"/>
    <SolidColorBrush x:Key="Accent"                Color="#007ACC"/>
    <SolidColorBrush x:Key="AccentHover"           Color="#1A8AD4"/>
    <SolidColorBrush x:Key="AccentPress"           Color="#005A9E"/>
    <SolidColorBrush x:Key="BorderColor"           Color="#3F3F46"/>
    <SolidColorBrush x:Key="Hover"                 Color="#2A2D2E"/>
    <SolidColorBrush x:Key="Selected"              Color="#094771"/>
    <SolidColorBrush x:Key="TabActive"             Color="#1E1E1E"/>
    <SolidColorBrush x:Key="TabInactive"           Color="#2D2D30"/>
    <SolidColorBrush x:Key="TabActiveIndicator"    Color="#007ACC"/>
    <SolidColorBrush x:Key="TreeHoverBg"           Color="#2A2D2E"/>
    <SolidColorBrush x:Key="TreeSelectedBg"        Color="#094771"/>
    <SolidColorBrush x:Key="TreeSelectedInactiveBg" Color="#37373D"/>
    <SolidColorBrush x:Key="FgTreeSelected"        Color="#FFFFFF"/>

    <!-- Markdown CSS colors (hex strings) -->
    <sys:String x:Key="MdBg">#1e1e1e</sys:String>
    <sys:String x:Key="MdFg">#c9d1d9</sys:String>
    <sys:String x:Key="MdHeading">#f0f6fc</sys:String>
    <sys:String x:Key="MdCode">#2d2d2d</sys:String>
    <sys:String x:Key="MdCodeFg">#e8912d</sys:String>
    <sys:String x:Key="MdCodeBlockFg">#c9d1d9</sys:String>
    <sys:String x:Key="MdBorder">#30363d</sys:String>
    <sys:String x:Key="MdLink">#58a6ff</sys:String>
    <sys:String x:Key="MdQuote">#8b949e</sys:String>
    <sys:String x:Key="MdTableEven">#161b22</sys:String>
    <sys:String x:Key="MdThHead">#161b22</sys:String>
    <sys:String x:Key="MdEm">#d2a8ff</sys:String>
    <sys:String x:Key="MdStrong">#f0f6fc</sys:String>
    <sys:String x:Key="MdScrollThumb">#4e5157</sys:String>
    <sys:String x:Key="MdScrollThumbHover">#7a7d83</sys:String>

</ResourceDictionary>
